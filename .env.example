# ============================================
# Find A Job - Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# Application
NEXT_PUBLIC_APP_NAME="Find A Job"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (PostgreSQL via Supabase or local)
DATABASE_URL="postgresql://user:password@localhost:5432/findajob?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/findajob?schema=public"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/onboarding
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase (for Realtime & Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# AI / OpenAI
OPENAI_API_KEY=sk-...

# Vector Database - Pinecone
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=candidates
PINECONE_ENVIRONMENT=us-east-1

# Search - Algolia
NEXT_PUBLIC_ALGOLIA_APP_ID=...
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=...
ALGOLIA_ADMIN_KEY=...
ALGOLIA_INDEX_NAME=jobs

# Payments - Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_FREE=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Redis (Upstash) - for rate limiting & caching
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Email - Resend
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@findajob.app

# Storage - AWS S3 or Cloudflare R2
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=findajob-uploads
AWS_S3_ENDPOINT=...

# Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=...

# Security
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
ENCRYPTION_KEY=your-encryption-key-32-chars-long